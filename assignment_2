# Step 1: Store first name in lowercase
first_name = "Abdul"

# Step 2: Store last name in uppercase
last_name = "Majeed"

# Step 3: Print greeting with case conversion
print("Hello, " + first_name.upper() + " " + last_name.lower())

# Step 4: Print two newlines
print("\n\n")

# Step 5: Create full name variable
full_name = first_name + " " + last_name

# Step 6: Slice last name from full_name and print (one line)
print(full_name[len(first_name) + 1:])

# Step 7: Replace last name with required format
updated_name = full_name.replace(last_name, last_name + ", Walsh College Student")
print(updated_name)

# Step 8: Print the quote with quotes included
print("\"Start by doing what's necessary; then do what's possible; and suddenly you are doing the impossible - Francis of Assisi\"")

# Step 9: Store two decimal numbers
num1 = 10.5
num2 = 2.5

# Step 10: Store arithmetic operations
addition = num1 + num2
subtraction = num1 - num2
multiplication = num1 * num2
division = num1 / num2

# Step 11: Print results using different techniques

# 1. Concatenation
print(str(num1) + " plus " + str(num2) + " equals " + str(addition))

# 2. String formatting expressions (%)
print("%s minus %s equals %s" % (num1, num2, subtraction))

# 3. format() method
print("{} multiplied by {} equals {}".format(num1, num2, multiplication))

# 4. f-string
print(f"{num1} divided by {num2} equals {division}")

# Step 12: Square root of multiplication result (2 decimal places)
import math
sq_root = round(math.sqrt(multiplication), 2)
print(f"The square root of {multiplication} equals {sq_root}")

# Step 13: Store current month and day
month = "April"
day = 12

# Step 14: Output with two tabs using a different method
print("\t\tToday is day {} of the month of {}.".format(day, month))


